{
  "name": "skyrio-monorepo",
  "private": true,
  "workspaces": [
    "frontend/my-app",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c yellow,cyan \"npm --workspace backend run dev\" \"npm --workspace frontend/my-app run dev\"",
    "build": "npm --workspace frontend/my-app run build",
    "start": "npm --workspace backend start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@sentry/react": "^10.51.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "mongodb": "^7.0.0"
  }
}
